# Copy this file to .env.local or export these values in your shell.
#
# GitHub Packages access is configured through Bundler, not this file:
#   bundle config https://rubygems.pkg.github.com/kanutocd GITHUB_USER:GITHUB_PAT
#
# The PAT needs read:packages. For private packages, it may also need repo.

REDIS_URL=redis://127.0.0.1:6379/0

CDC_REDIS_PRO_LICENSE_KEY=cdc-license-v1...
CDC_REDIS_PRO_LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
...
-----END PUBLIC KEY-----"

CDC_ORCHESTRATOR_PRO_LICENSE_KEY=$CDC_REDIS_PRO_LICENSE_KEY
CDC_ORCHESTRATOR_PRO_LICENSE_PUBLIC_KEY=$CDC_REDIS_PRO_LICENSE_PUBLIC_KEY
